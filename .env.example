# Application environment (production, development, testing)
APP_ENV=development
FLASK_ENV=development

# python -c "import secrets; print(secrets.token_hex(16))"
FLASK_SECRET_KEY=

MAIN_DIR=~/data

TOOL_TOOLSDB_DBNAME=svg_langs

# TOOL_TOOLSDB_HOST=tools.db.svc.wikimedia.cloud
TOOL_TOOLSDB_HOST=127.0.0.1

TOOL_TOOLSDB_USER=root
TOOL_TOOLSDB_PASSWORD=root

# Uploads disabled untill OAuth is ready
DISABLE_UPLOADS=0

OAUTH_MWURI=https://commons.wikimedia.org/w/index.php
OAUTH_CONSUMER_KEY=
OAUTH_CONSUMER_SECRET=

# Generate URL-safe 32-byte Fernet key:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OAUTH_ENCRYPTION_KEY=

AUTH_COOKIE_NAME=name
AUTH_COOKIE_MAX_AGE=2592000  # 30 days
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
UPLOAD_END_POINT=commons.wikimedia.org

USER_AGENT=

REQUEST_TOKEN_SESSION_KEY=state
STATE_SESSION_KEY=oauth_state

DEV_DOWNLOAD_LIMIT=10

# Credentials used by offline maintenance scripts in _works_files/
# (e.g. rename_owid_pages.py). Generate at:
#   https://commons.wikimedia.org/wiki/Special:BotPasswords
# Use the "User@Botname" form for WIKI_USERNAME.
WIKI_USERNAME=
WIKI_PASSWORD=
